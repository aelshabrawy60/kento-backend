// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CLIENT
  VENDOR
  ADMIN
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String?
  password       String
  phone          String?
  role           Role
  region         String?
  profilePicture String?
  createdAt      DateTime @default(now())

  refreshTokens RefreshToken[]
  client        Client?
  vendor        Vendor?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Client {
  id         String      @id @default(uuid())
  userId     String      @unique
  user       User        @relation(fields: [userId], references: [id])
  reviews    Review[]
  savedPosts SavedPost[]
  contracts  Contract[]
}

model Vendor {
  id             String          @id @default(uuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id])
  category       String?
  about          String?
  price          Int?
  experience     Int?
  portfolioUrl   String?
  type           Int?
  profileStatus  ProfileStatus   @default(UNDER_REVIEW)
  topImageUrl    String?
  rating         Float?
  portfolioPosts PortfolioPost[]
  reviews        Review[]
  contracts      Contract[]
}

model PortfolioPost {
  id         String      @id @default(uuid())
  vendorId   String
  vendor     Vendor      @relation(fields: [vendorId], references: [id])
  hashtags   String[]
  mediaUrls  String[]
  createdAt  DateTime    @default(now())
  savedPosts SavedPost[]
}

model Review {
  id        String   @id @default(uuid())
  vendorId  String
  clientId  String
  raterName String?
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  client    Client   @relation(fields: [clientId], references: [id])
  value     Int
  comment   String?
  mediaUrls String[]
  rater     Role
}

model SavedPost {
  id        String        @id @default(uuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  postId    String
  post      PortfolioPost @relation(fields: [postId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([clientId, postId])
}

model Contract {
  id           String         @id @default(uuid())
  clientId     String
  vendorId     String
  client       Client         @relation(fields: [clientId], references: [id])
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  createdAt    DateTime       @default(now())
  completedAt  DateTime?
  status       ContractStatus @default(PENDING)
  description  String?
  title        String?
  price        Float?
  deposit      Float?
  startDate    DateTime
  deliveryDate DateTime?
}

enum ContractStatus {
  OFFERED // wating for offer from vendor
  PENDING // waiting for payment
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProfileStatus {
  UNDER_REVIEW
  APPROVED
  REJECTED
}
